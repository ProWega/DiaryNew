# Copy this file to .env.docker on the Ubuntu server and replace every secret.
# Canonical release flow: update APP_IMAGE to a pinned Docker Hub tag, then run
# docker compose --env-file .env.docker pull && docker compose --env-file .env.docker up -d

APP_IMAGE=prowega/newdiary:latest
APP_PORT=4000
APP_BASE_URL=https://example.com

POSTGRES_DB=newdiary
POSTGRES_USER=newdiary
POSTGRES_PASSWORD=replace-with-strong-db-password

AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_NAME=newdiary_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

SETUP_TOKEN=replace-with-first-admin-setup-token
MAGIC_LINK_TTL_MINUTES=60
ALLOW_DEMO_SEED=false

# ── Curator AI v2 — LLM-обогащение и чат куратора ─────────────────────────
# Провайдер выбирается по prefix модели в settings.llm.defaultModel:
#   claude-* → Anthropic, gpt-* / o3* / o4* → OpenAI.
# Без ключей endpoint всё равно работает (structured brief, source:"fallback").

# Anthropic (Claude Haiku/Sonnet/Opus)
ANTHROPIC_API_KEY=
# Релей для регионов с ограничениями (oneprovider.dev и т.п.):
ANTHROPIC_BASE_URL=
# Прокси к api.anthropic.com (http://user:pass@host:port или socks5://...):
ANTHROPIC_PROXY_URL=

# OpenAI (GPT-5 mini / GPT-5 / GPT-4o)
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Если пуст — используется ANTHROPIC_PROXY_URL как fallback.
OPENAI_PROXY_URL=
