# ────────────────────────────────────────────────────────────────────────
#  newdiary — production .env (server bundle)
#  Скопируйте в `.env` рядом с docker-compose.yml и замените все секреты.
# ────────────────────────────────────────────────────────────────────────

# ── Образ из Docker Hub ─────────────────────────────────────────────────
# Для production пиньте к immutable git-sha (rollback одной правкой):
#   APP_IMAGE=prowega/newdiary:90ee176-dirty
# Для dev можно :latest, но тогда нет гарантий что pull даст ту же версию.
APP_IMAGE=prowega/newdiary:latest

# ── Домен и базовый URL ─────────────────────────────────────────────────
# APP_BASE_URL — то, что фронт видит в браузере. Используется для генерации
# magic-link URL'ов в email/SMS. Должен совпадать с доменом в Caddyfile.
APP_BASE_URL=https://example.com

# CORS — кроме APP_BASE_URL обычно ничего не нужно. Пустой = только same-origin.
CORS_ALLOWED_ORIGINS=https://example.com

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_DB=newdiary
POSTGRES_USER=newdiary
# Сгенерируйте: openssl rand -base64 32
POSTGRES_PASSWORD=replace-with-strong-db-password

# ── Auth-сессии ────────────────────────────────────────────────────────
# Сгенерируйте: openssl rand -hex 32
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_NAME=newdiary_session
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# ── First-admin setup ───────────────────────────────────────────────────
# Этот токен нужен ровно один раз — для POST /api/setup/admin (создание
# первого администратора). После создания можно убрать или оставить пустым.
# Генерируйте: openssl rand -hex 24
SETUP_TOKEN=replace-with-first-admin-setup-token

# ── Magic-link / прочее ─────────────────────────────────────────────────
MAGIC_LINK_TTL_MINUTES=60
ALLOW_DEMO_SEED=false

# ── Anthropic (LLM-обогащение narrative-brief куратора) ─────────────────
# Опционально. Если ANTHROPIC_API_KEY пустой — используется детерминированный
# fallback (без LLM). Из РФ Anthropic API заблокирован, два варианта обхода
# (использовать что-то одно):
#   1) ANTHROPIC_BASE_URL=https://api.oneprovider.dev — релей, доступен из РФ.
#      Ключ ANTHROPIC_API_KEY тоже от этого релея, не от Anthropic.
#   2) ANTHROPIC_PROXY_URL=socks5://user:pass@host:port — SOCKS5/HTTP туннель
#      к настоящему api.anthropic.com. Ключ от Anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_PROXY_URL=

# ── OpenAI (альтернативный провайдер для chat/brief) ────────────────────
# Используется автоматически когда организатор выбирает модель gpt-*.
# OPENAI_PROXY_URL опционален: если пуст, используется тот же
# ANTHROPIC_PROXY_URL. OPENAI_BASE_URL — для альтернативных релеев типа
# https://api.proxyapi.ru/openai.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_PROXY_URL=
