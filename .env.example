PORT=4000
HOST=0.0.0.0
APP_MODE=development
APP_BASE_URL=http://localhost:5173

# Auth / deployment. Use strong unique values in production.
AUTH_SESSION_SECRET=change-me-in-production
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_NAME=newdiary_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
SETUP_TOKEN=change-me-for-first-admin
MAGIC_LINK_TTL_MINUTES=60

# Demo data is blocked in production unless explicitly allowed.
ALLOW_DEMO_SEED=false

# PostgreSQL connection. Use either DATABASE_URL or PG* variables below.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/newdiary

PGHOST=localhost
PGPORT=5432
PGDATABASE=newdiary
PGUSER=postgres
PGPASSWORD=1234
PGSSL=false
