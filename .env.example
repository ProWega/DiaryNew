PORT=4000
HOST=0.0.0.0
APP_MODE=development
APP_BASE_URL=http://localhost:5173

# Comma-separated list of origins allowed to send credentialed requests.
# Leave empty in development to fall back to localhost defaults.
# REQUIRED in production: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Rate limit applied to /api/auth/* (per IP).
AUTH_RATE_LIMIT_WINDOW_MIN=15
AUTH_RATE_LIMIT_MAX=50

# Pino log level: trace | debug | info | warn | error | fatal.
# Defaults to "debug" in development and "info" in production.
LOG_LEVEL=

# Auth / deployment. Use strong unique values in production.
AUTH_SESSION_SECRET=change-me-in-production
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_NAME=newdiary_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
SETUP_TOKEN=change-me-for-first-admin
MAGIC_LINK_TTL_MINUTES=60

# Demo data is blocked in production unless explicitly allowed.
ALLOW_DEMO_SEED=false

# PostgreSQL connection. Use either DATABASE_URL or PG* variables below.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/newdiary

PGHOST=localhost
PGPORT=5432
PGDATABASE=newdiary
PGUSER=postgres
PGPASSWORD=postgres
PGSSL=false

# Observability — all opt-in. Without these, telemetry/error reporting is silently disabled.
# Backend: OpenTelemetry traces (auto-instruments Express + pg). Set to your collector URL.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=newdiary-api

# Frontend (Vite) — Sentry error reporting. Set the DSN from your Sentry project.
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENVIRONMENT=development

# Curator AI v2 — LLM-обогащение narrative brief куратора и чат «Разговор с ИИ».
# Провайдер выбирается автоматически по prefix модели (см. SessionLlmSettingsCard
# в кабинете организатора): claude-* → Anthropic, gpt-* / o3* / o4* → OpenAI.
# Оба ключа опциональны: без них endpoint всё равно отдаёт структурированный
# brief (source: "fallback"), но генерация narrative/chat будет недоступна.

# ── Anthropic (Claude Haiku 4.5 / Sonnet 4.5 / Opus 4.7) ──────────────────
# ANTHROPIC_API_KEY=
# Альтернативный endpoint для релеев, доступных из РФ (oneprovider.dev и т.п.).
# Ключ должен быть от релея, не от Anthropic.
# ANTHROPIC_BASE_URL=
# Proxy / VPN туннель для прямых вызовов api.anthropic.com.
# Auto-detect: http(s):// → undici.ProxyAgent, socks(5):// → socks-proxy-agent.
# ANTHROPIC_PROXY_URL=

# ── OpenAI (GPT-5 mini / GPT-5 / GPT-4o / GPT-4o mini) ────────────────────
# OPENAI_API_KEY=
# Альтернативный endpoint (proxyapi.ru/openai и т.п.).
# OPENAI_BASE_URL=
# Если пуст — используется ANTHROPIC_PROXY_URL как fallback (тот же провайдер
# прокси обычно работает для обоих API). HTTP стабильнее SOCKS5 на fetch-based SDK.
# OPENAI_PROXY_URL=
