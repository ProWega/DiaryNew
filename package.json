{
  "name": "newdiary",
  "version": "1.0.0",
  "private": true,
  "description": "Prototype of a diary and analytics platform for forum participants.",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "nodemon server/index.cjs",
    "start:server": "node server/index.cjs",
    "db:schema": "node server/scripts/applySchema.cjs",
    "db:seed": "node server/seed/seedDatabase.cjs",
    "db:reset": "node server/scripts/resetDatabase.cjs",
    "db:check": "node server/scripts/checkDatabase.cjs",
    "prod:init": "npm run db:schema",
    "build": "vite build",
    "storybook": "storybook dev -p 6006 --disable-telemetry",
    "build-storybook": "storybook build --disable-telemetry",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:generate": "node scripts/docs/generateReference.cjs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check": "node scripts/docs/generateReference.cjs --check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "storybook": "^10.3.5",
    "vite": "^8.0.7",
    "vitepress": "^1.6.4"
  }
}
